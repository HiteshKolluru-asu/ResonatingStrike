  "key_narratives": [
    {
      "narrative": "BLG's Dominant Run",
      "description": "BLG went nearly undefeated through the entire tournament, dropping only Game 3 of the finals. They swept every opponent in groups and semis before winning the finals 3-1."
    },
    {
      "narrative": "Western Hope — G2's Run",
      "description": "G2 Esports defied expectations by sweeping Gen.G 3-0 in the semis and reaching the finals. Despite losing 1-3 to BLG, they represented the best Western performance in recent memory. The narrative of 'Western fans having hope' was a major community theme."
    },
    {
      "narrative": "Caps Legacy",
      "description": "Caps continued his multi-year legacy of being the player who carries EU at international tournaments. From 2020 to 2026, the community observed it's always Caps dragging Europe forward."
    },
    {
      "narrative": "SkewMond Breakout",
      "description": "SkewMond emerged as a star at First Stand, particularly in the Gen.G sweep where he massively outjungled Canyon."
    },
    {
      "narrative": "Bin the Western Slayer",
      "description": "Bin's dominance over Western top laners, especially in the finals, became a 'canon event' meme. His Jax play was highlighted as a key factor in BLG's victory."
    },
    {
      "narrative": "East vs West Gap",
      "description": "First Stand 2026 was on pace to be one of the most one-sided major internationals in LoL history. The community debated whether Western LoL is 'beyond saving' despite G2's run."
    },
    {
      "narrative": "LCK Disappointment",
      "description": "Both LCK teams (Gen.G and BFX) were eliminated without winning a single series in the knockout stage. Gen.G's 0-3 loss to G2 was particularly shocking."
    },
    {
      "narrative": "China's Return",
      "description": "BLG's victory marked China's first major international title since 2023, ending a drought."
